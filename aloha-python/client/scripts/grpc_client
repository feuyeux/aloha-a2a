#!/bin/bash
cd "$(dirname "$0")/../.."
if command -v uv &> /dev/null; then
    uv run --project client python -m client --transport grpc --port 13000 --message "Roll a 6-sided dice"
elif [ -x "client/.venv/bin/python" ]; then
    client/.venv/bin/python -m client --transport grpc --port 13000 --message "Roll a 6-sided dice"
else
    python -m client --transport grpc --port 13000 --message "Roll a 6-sided dice"
fi
